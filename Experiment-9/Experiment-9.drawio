    <mxGraphModel dx="3253" dy="3302" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="H2yL56X9xETrzGftKFqc-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h1&gt;Online Ticket Booking System&lt;/h1&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="750" as="geometry" />
        </mxCell>
        <mxCell id="H2yL56X9xETrzGftKFqc-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;Functional Requirements&lt;/h2&gt;&lt;h3&gt;1)&amp;nbsp;&lt;font face=&quot;Times New Roman&quot;&gt;The user must be able to view comprehensive details for a specific event such as the&amp;nbsp;&lt;/font&gt;&lt;font face=&quot;Times New Roman&quot;&gt;no. of seats, the meta data like cast duration etc.&lt;/font&gt;&lt;/h3&gt;&lt;h3&gt;&lt;font face=&quot;Times New Roman&quot;&gt;2)&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Times New Roman&quot;&gt;The user must be able to discover events using filters such as the Event Title, the City/Location, and the specific Date of the show.&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h3&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Times New Roman&quot;&gt;3) The User Be able to book the ticket and complete the transaction via payment service.&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="596" x="74" y="80" as="geometry" />
        </mxCell>
        <mxCell id="H2yL56X9xETrzGftKFqc-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;Non Functional Requirements&lt;/h2&gt;&lt;h3&gt;1) CAP Theorem&amp;nbsp;&lt;br&gt;Consistency &amp;gt;&amp;gt; Availability ( No Double Booking )&amp;nbsp; &amp;nbsp;(For Booking Service)&lt;/h3&gt;&lt;h3&gt;Availability &amp;gt;&amp;gt; Consistency ( For Searching and View)&lt;/h3&gt;&lt;div&gt;&lt;h3&gt;2) Reads &amp;gt;&amp;gt; Writes ( Daily Active Users&amp;nbsp; 100M DAU)&lt;/h3&gt;&lt;/div&gt;&lt;h3&gt;3) Scalability To Handle Popular events ( Heavy Traffic )&lt;/h3&gt;" vertex="1">
          <mxGeometry height="170" width="566" x="74" y="340" as="geometry" />
        </mxCell>
        <mxCell id="H2yL56X9xETrzGftKFqc-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2 style=&quot;&quot;&gt;Core Entities Of The System&lt;/h2&gt;&lt;h2 style=&quot;&quot;&gt;1) Event&amp;nbsp;&lt;br&gt;2) Venue&amp;nbsp;&lt;br&gt;3) Performer&lt;br&gt;4) Ticket&lt;/h2&gt;" vertex="1">
          <mxGeometry height="175" width="266" x="74" y="550" as="geometry" />
        </mxCell>
        <mxCell id="H2yL56X9xETrzGftKFqc-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;API DESIGN&lt;/h2&gt;&lt;h3&gt;1) GET /event/{event_id}&amp;nbsp; -------&amp;gt;&amp;gt;&amp;nbsp; &amp;nbsp;Event &amp;amp; Venue &amp;amp; Performer &amp;amp; Ticket&lt;/h3&gt;&lt;h3&gt;2) GET /search?term={term}&amp;amp;location={location}&amp;amp;type={type}&amp;amp;date={date}&lt;br&gt;------&amp;gt;&amp;gt; Metadata of the Event&lt;/h3&gt;&lt;h3&gt;3) Post /booking/reserve&lt;br&gt;header : JWT | sessionToken&lt;br&gt;body :{ ticket_id }&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;br&gt;&lt;br&gt;4) Put /booking/confirm&lt;br&gt;header : JWT | sessionToken&lt;br&gt;body : { ticket_id , PaymentDetails }&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="410" width="700" x="80" y="780" as="geometry" />
        </mxCell>
        <mxCell id="H2yL56X9xETrzGftKFqc-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;High Level Design&lt;/h2&gt;" vertex="1">
          <mxGeometry height="40" width="230" x="700" y="1300" as="geometry" />
        </mxCell>
